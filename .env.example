# Copie este arquivo para .env e preencha com valores reais.
# O .env NUNCA deve ser commitado.

# Aplicação
APP_HOST=http://localhost:3000
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# Admin inicial (usado pelo db:seed)
INITIAL_ADMIN_EMAIL=admin@synaxis.local
INITIAL_ADMIN_PASSWORD=changeme123

# Banco de dados PostgreSQL (schema sch_synaxis_koinonia)
DEFAULT_DATABASE_HOST=localhost
DEFAULT_DATABASE_NAME=synaxis_koinonia_development
DEFAULT_DATABASE_USERNAME=synaxis
DEFAULT_DATABASE_PASSWORD=synaxis
RAILS_MAX_THREADS=5

# Redis / Sidekiq
REDIS_URL=redis://localhost:6379/0

# SMTP
SMTP_ADDRESS=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
SMTP_DOMAIN=synaxis.local
MAILER_FROM="Synaxis Koinonia <no-reply@synaxis.local>"

# reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Instagram Graph API (conta Business/Creator)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Facebook Graph API (Page)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# X / Twitter API v2
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Controle operacional
# true desabilita chamadas reais às APIs sociais (útil em dev sem credenciais)
DISABLE_SOCIAL_PUBLISHING=false

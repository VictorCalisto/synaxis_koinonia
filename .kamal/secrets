# Secrets carregados em produção. NÃO commitar credenciais reais.
# Este arquivo apenas referencia as variáveis — os valores vêm do ambiente
# do operador (password manager, shell ENV, ou Rails credentials).

# Rails
RAILS_MASTER_KEY=$(cat config/master.key)
SECRET_KEY_BASE=$SECRET_KEY_BASE

# Banco PostgreSQL (acessório kamal "postgres")
DEFAULT_DATABASE_HOST=$DEFAULT_DATABASE_HOST
DEFAULT_DATABASE_NAME=$DEFAULT_DATABASE_NAME
DEFAULT_DATABASE_USERNAME=$DEFAULT_DATABASE_USERNAME
DEFAULT_DATABASE_PASSWORD=$DEFAULT_DATABASE_PASSWORD
POSTGRES_PASSWORD=$DEFAULT_DATABASE_PASSWORD

# Redis (acessório kamal "redis")
REDIS_URL=$REDIS_URL

# SMTP
SMTP_ADDRESS=$SMTP_ADDRESS
SMTP_PORT=$SMTP_PORT
SMTP_USERNAME=$SMTP_USERNAME
SMTP_PASSWORD=$SMTP_PASSWORD
SMTP_DOMAIN=$SMTP_DOMAIN
MAILER_FROM=$MAILER_FROM

# reCAPTCHA v3
RECAPTCHA_SITE_KEY=$RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=$RECAPTCHA_SECRET_KEY

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=$INSTAGRAM_ACCESS_TOKEN
INSTAGRAM_BUSINESS_ACCOUNT_ID=$INSTAGRAM_BUSINESS_ACCOUNT_ID

# Facebook Graph API
FACEBOOK_PAGE_ID=$FACEBOOK_PAGE_ID
FACEBOOK_PAGE_ACCESS_TOKEN=$FACEBOOK_PAGE_ACCESS_TOKEN

# X / Twitter API v2
X_API_KEY=$X_API_KEY
X_API_SECRET=$X_API_SECRET
X_BEARER_TOKEN=$X_BEARER_TOKEN
X_ACCESS_TOKEN=$X_ACCESS_TOKEN
X_ACCESS_SECRET=$X_ACCESS_SECRET

